rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Auth helper ──────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null;
    }

    // ─── Public-read content (managed by admin panel) ────────────────────────
    match /causes/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /events/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blog/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /testimonials/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /stats/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Form submission collections ─────────────────────────────────────────
    // Public: create only (website forms write here)
    // Admin:  full access (admin panel reads/updates/deletes)

    match /contacts/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /volunteers/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /donations/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /newsletter/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /event_registrations/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
